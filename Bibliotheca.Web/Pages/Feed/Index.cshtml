@page
@model Bibliotheca.Web.Pages.Feed.IndexModel

@if (!Model.Books.Items.Any())
{
    <p>Nenhum livro encontrado.</p>
}
else
{
    <ul class="list-group">
        @foreach (var book in Model.Books.Items)
        {
            <li class="list-group-item">
                <a asp-page="/Feed/Details" asp-route-id="@book.Id"><strong>@book.Name</strong></a>
                <span class="text-muted"> — @book.Author (@book.PublicationYear)</span>
            </li>
        }
    </ul>

    @if (Model.Books.TotalPages > 1)
    {
        <nav>
            <ul class="pagination">
                <li class="page-item @(Model.Books.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" asp-page="/Feed/Index" asp-all-route-data="@Model.RouteValuesForPage(Model.PageNumber - 1)">Anterior</a>
                </li>
                <li class="page-item disabled">
                    <span class="page-link">Página @Model.Books.PageNumber de @Model.Books.TotalPages</span>
                </li>
                <li class="page-item @(Model.Books.HasNextPage ? "" : "disabled")">
                    <a class="page-link" asp-page="/Feed/Index" asp-all-route-data="@Model.RouteValuesForPage(Model.PageNumber + 1)">Próxima</a>
                </li>
            </ul>
        </nav>
    }
}