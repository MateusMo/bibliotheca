@page
@model Bibliotheca.Web.Pages.Profile.Books.CreateModel
@{
    ViewData["Title"] = "Cadastrar livro";
}

<h1>Cadastrar livro</h1>

@if (Model.ErrorMessage is not null)
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<form method="post">
    <div class="mb-3">
        <label asp-for="Input.Name" class="form-label">Título</label>
        <input asp-for="Input.Name" class="form-control"/>
        <span asp-validation-for="Input.Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Input.Author" class="form-label">Autor</label>
        <input asp-for="Input.Author" class="form-control"/>
        <span asp-validation-for="Input.Author" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Input.Description" class="form-label">Descrição</label>
        <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Input.Description" class="text-danger"></span>
    </div>

    <div class="form-check mb-3">
        <input asp-for="Input.IsOwner" class="form-check-input"/>
        <label asp-for="Input.IsOwner" class="form-check-label">Você possui este livro</label>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="Input.PublicationYear" class="form-label">Ano de publicação</label>
            <input asp-for="Input.PublicationYear" class="form-control"/>
            <span asp-validation-for="Input.PublicationYear" class="text-danger"></span>
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="Input.LanguageEnum" class="form-label">Idioma</label>
            <select asp-for="Input.LanguageEnum" class="form-select">
                @foreach (var value in Enum.GetValues<Bibliotheca.Domain.Enums.LanguageEnum>())
                {
                    <option value="@value">@value</option>
                }
            </select>
            <span asp-validation-for="Input.LanguageEnum" class="text-danger"></span>
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="Input.Publisher" class="form-label">Editora</label>
            <input asp-for="Input.Publisher" class="form-control"/>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Input.ISBN" class="form-label">ISBN</label>
            <input asp-for="Input.ISBN" class="form-control"/>
            <span asp-validation-for="Input.ISBN" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="Input.Pages" class="form-label">Páginas</label>
            <input asp-for="Input.Pages" class="form-control"/>
            <span asp-validation-for="Input.Pages" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Input.EstimatedValue" class="form-label">Valor estimado</label>
            <input asp-for="Input.EstimatedValue" class="form-control"/>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="Input.ConditionEnum" class="form-label">Condição</label>
            <select asp-for="Input.ConditionEnum" class="form-select">
                @foreach (var value in Enum.GetValues<Bibliotheca.Domain.Enums.BookConditionEnum>())
                {
                    <option value="@value">@value</option>
                }
            </select>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Input.PhotosText" class="form-label">Fotos (URLs separadas por vírgula)</label>
        <textarea asp-for="Input.PhotosText" class="form-control" rows="2"
                  placeholder="Upload de imagens ainda não implementado — por enquanto, cole URLs aqui."></textarea>
    </div>

    <button type="submit" class="btn btn-primary">Salvar</button>
    <a asp-page="/Profile/Index" class="btn btn-outline-secondary">Cancelar</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}