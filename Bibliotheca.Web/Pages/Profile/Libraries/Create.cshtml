@page
@model Bibliotheca.Web.Pages.Profile.Libraries.CreateModel
@{
    ViewData["Title"] = "Nova biblioteca";
}

<h1>Nova biblioteca</h1>

@if (Model.ErrorMessage is not null)
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<form method="post">
    <div class="mb-3">
        <label asp-for="Input.Title" class="form-label">Título</label>
        <input asp-for="Input.Title" class="form-control"/>
        <span asp-validation-for="Input.Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Input.Description" class="form-label">Descrição</label>
        <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Input.Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Livros</label>
        @if (!Model.AvailableBooks.Any())
        {
            <p class="text-muted">Você ainda não cadastrou nenhum livro para associar.</p>
        }
        else
        {
            <div class="border rounded p-2" style="max-height: 300px; overflow-y: auto;">
                @foreach (var book in Model.AvailableBooks)
                {
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" name="Input.SelectedBookIds" value="@book.Id" id="book_@book.Id"/>
                        <label class="form-check-label" for="book_@book.Id">@book.Name — @book.Author</label>
                    </div>
                }
            </div>
        }
    </div>

    <button type="submit" class="btn btn-primary">Salvar</button>
    <a asp-page="/Profile/Libraries/Index" class="btn btn-outline-secondary">Cancelar</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}