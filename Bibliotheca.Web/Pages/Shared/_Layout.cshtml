<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Bibliotheca</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/Bibliotheca.Web.styles.css" asp-append-version="true"/>
</head>
<body>
<nav class="navbar navbar-expand-sm">
    <div class="container d-flex justify-content-between align-items-center">
        <a class="navbar-brand" asp-page="/Feed/Index">Bibliotheca</a>
        <div class="d-flex gap-4 align-items-center">
            <a class="nav-link d-inline" asp-page="/Feed/Index">Feed</a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a class="nav-link d-inline" asp-page="/Profile/Libraries/Index">Minha Biblioteca</a>
                <a class="nav-link d-inline" asp-page="/Profile/Index">@User.Identity!.Name</a>
                <a class="nav-link d-inline" asp-page="/Account/Logout">Sair</a>
            }
            else
            {
                <a class="nav-link d-inline" asp-page="/Account/Login">Entrar</a>
                <a class="nav-link d-inline" asp-page="/Account/Register">Cadastre-se</a>
            }
        </div>
    </div>
</nav>

<div class="container page-content">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="footer">
    <div class="container">
        &copy; 2026 - Bibliotheca
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>