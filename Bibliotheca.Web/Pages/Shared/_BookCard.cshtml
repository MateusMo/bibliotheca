@model Bibliotheca.Web.ViewModels.BookCardViewModel

<div class="card h-100">
    <div class="card-body d-flex flex-column">
        <span class="badge bg-primary align-self-start mb-2">📘 Livro</span>
        <h5 class="card-title">
            <a asp-page="/Feed/Details" asp-route-id="@Model.Id" asp-route-slug="@Model.Slug">@Model.Name</a>
        </h5>
        <h6 class="card-subtitle mb-2 text-muted">@Model.Author — @Model.PublicationYear</h6>

        <p class="card-text small text-muted mb-1">
            por <strong>@Model.UserName</strong> · pontuação do perfil: @Model.ProfileScore
        </p>
        <p class="card-text small text-muted mb-1">
            Adicionado em @Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")
        </p>
        <p class="card-text small text-muted mt-auto mb-0">
            @Model.PhotoCount foto(s) · @Model.Language · @Model.Condition ·
            @Model.ViewCount visualizaç@(Model.ViewCount == 1 ? "ão" : "ões")
        </p>
    </div>
</div>