@page
@model Bibliotheca.Web.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Entrar";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h1>Entrar</h1>

        @if (Model.ErrorMessage is not null)
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        <form method="post" asp-route-returnUrl="@Model.ReturnUrl">
            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label">E-mail</label>
                <input asp-for="Input.Email" class="form-control"/>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label">Senha</label>
                <input asp-for="Input.Password" type="password" class="form-control"/>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary">Entrar</button>
        </form>

        <p class="mt-3">
            Não tem conta? <a asp-page="/Account/Register">Cadastre-se</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}